### SmartRiver environment variables (example)
### Copy to `.env` and update values.

## Database
# PostgreSQL (optional; current backend also uses SQLite by default for auth/feedback)
DATABASE_URL=postgresql://user:password@localhost:5432/smartriver

# SQLite path used by backend repository (auth + feedback persistence)
SMARTRIVER_SQLITE_PATH=backend/db/smartriver.sqlite3

# If true, admin CSV upload rejects files with station codes not listed in RIVER_NAME_BY_STATION_CODE
# (see backend/services/river_mapping.py). Default: unknown codes map to "Unknown River" with warnings.
# SMARTRIVER_STRICT_STATION_CODES=1

## Auth / JWT
# Used by backend/auth/auth_service.py (prefers JWT_SECRET_KEY, falls back to SECRET_KEY)
JWT_SECRET_KEY=your-jwt-secret-change-in-production
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

## Email / OTP (registration & password reset)
# 0 = send real email via SMTP/SendGrid; 1 = print OTP to server console only (no inbox)
SMARTRIVER_OTP_DEV_LOG=0

# Gmail: enable 2-Step Verification, then create an App Password at
# https://myaccount.google.com/apppasswords — paste the 16 characters into SMTP_PASSWORD
# (spaces in the app password are OK; the backend strips them for SMTP login).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM_EMAIL=your_gmail@gmail.com
SMTP_FROM_NAME=SmartRiver System
OTP_EXPIRE_MINUTES=10

# Optional: SendGrid instead of SMTP
# SENDGRID_API_KEY=

# Optional: allow GET /api/v1/auth/test-email when APP_ENV=production (default: allowed when not production)
# SMARTRIVER_ALLOW_TEST_EMAIL=1

## Backend app
APP_ENV=development
DEBUG=true
FRONTEND_URL=http://localhost:3000

