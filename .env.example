# Copy to .env for local dev; set these in Render Dashboard → Environment for production.

# Required in production (Render can auto-generate)
JWT_SECRET_KEY=change-me-to-a-long-random-string

# Optional — email OTP (or use SMARTRIVER_OTP_DEV_LOG=true to print codes in server logs)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=your@gmail.com

# Production tuning
SMARTRIVER_DEFER_FORECAST=true
SMARTRIVER_OTP_DEV_LOG=true
SMARTRIVER_SQLITE_PATH=/tmp/smartriver.sqlite3
